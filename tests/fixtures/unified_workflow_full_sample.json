{
  "id": "bbbbbbbb-cccc-4ddd-8eee-ffffffffffff",
  "name": "Full runner step coverage",
  "description": "Exercises every FullRunnerStep variant across the four workflow phases — acts as a cross-language DB round-trip fixture.",
  "category": "ci",
  "tags": [
    "coverage",
    "round-trip",
    "example"
  ],
  "setupSteps": [
    {
      "type": "command",
      "id": "setup-clone-0001",
      "name": "Clone repo",
      "phase": "setup",
      "mode": "shell",
      "command": "git clone https://github.com/jspahrsummers/qontinui-runner.git /tmp/runner",
      "workingDirectory": "/tmp",
      "timeoutSeconds": 120,
      "failOnError": true
    },
    {
      "type": "command",
      "id": "setup-lint-0002",
      "name": "Cargo clippy",
      "phase": "setup",
      "mode": "check",
      "checkType": "lint",
      "tool": "cargo-clippy",
      "command": "cargo clippy --all-targets -- -D warnings",
      "workingDirectory": "/tmp/runner/src-tauri"
    },
    {
      "type": "ui_bridge",
      "id": "setup-nav-0003",
      "name": "Open runner home page",
      "phase": "setup",
      "action": "navigate",
      "url": "http://localhost:1420/",
      "timeoutMs": 15000
    },
    {
      "type": "code_execution",
      "id": "setup-pycheck-0004",
      "name": "Probe DB readiness",
      "code": "import psycopg2; psycopg2.connect('postgresql://localhost/qontinui').close(); print('db-ok')",
      "sandboxMode": "enforce",
      "timeoutSeconds": 20
    },
    {
      "type": "restart_process",
      "id": "setup-restart-0005",
      "name": "Restart backend before tests",
      "restartProcessName": "qontinui-backend",
      "restartWaitForHealth": true,
      "timeoutSeconds": 60
    }
  ],
  "verificationSteps": [
    {
      "type": "command",
      "id": "verify-tests-0101",
      "name": "Run cargo test",
      "phase": "verification",
      "mode": "test",
      "testType": "repository",
      "command": "cargo test --workspace",
      "workingDirectory": "/tmp/runner/src-tauri",
      "timeoutSeconds": 600,
      "failOnError": true
    },
    {
      "type": "ui_bridge",
      "id": "verify-assert-0102",
      "name": "Assert login button visible",
      "phase": "verification",
      "action": "assert",
      "target": "#login-button",
      "assertType": "visible",
      "expected": "true",
      "timeoutMs": 8000
    },
    {
      "type": "ui_bridge_visual_assertion",
      "id": "verify-visual-0103",
      "name": "Assert header text",
      "visualAssertionType": "text",
      "visualAssertionQuery": {
        "role": "heading",
        "level": 1
      },
      "visualAssertionExpected": "Qontinui Runner",
      "timeoutSeconds": 10
    },
    {
      "type": "workflow_fixup",
      "id": "verify-fixup-0104",
      "name": "Validate generated workflow",
      "fixupInputPath": "{{artifact_dir}}/workflow.json",
      "fixupMode": "validate_criteria",
      "fixupCriteriaPath": "{{artifact_dir}}/criteria.json"
    }
  ],
  "agenticSteps": [
    {
      "type": "prompt",
      "id": "agentic-fix-0201",
      "name": "Fix failing tests",
      "phase": "agentic",
      "content": "Read the failing cargo test output and propose a minimal patch that makes the tests pass without regressing behaviour.",
      "provider": "anthropic",
      "model": "claude-opus-4-6"
    },
    {
      "type": "native_accessibility",
      "id": "agentic-a11y-0202",
      "name": "Snapshot active window",
      "action": "ai_context",
      "target": "Desktop",
      "interactiveOnly": true,
      "maxElements": 50,
      "timeoutSeconds": 15
    }
  ],
  "completionSteps": [
    {
      "type": "command",
      "id": "complete-report-0301",
      "name": "Emit summary report",
      "phase": "completion",
      "mode": "shell",
      "command": "python scripts/emit_summary.py --artifact-dir {{artifact_dir}}",
      "workingDirectory": "/tmp/runner"
    },
    {
      "type": "save_workflow_artifact",
      "id": "complete-save-0302",
      "name": "Persist generated workflow",
      "artifactInputPath": "{{artifact_dir}}/workflow.json",
      "artifactCapturePrompts": true
    },
    {
      "type": "workflow",
      "id": "complete-subwf-0303",
      "name": "Run notification subworkflow",
      "phase": "completion",
      "workflowId": "wf-notify-9001",
      "workflowName": "Post-run notification"
    },
    {
      "type": "ui_bridge_design_audit",
      "id": "complete-audit-0304",
      "name": "Design audit on final page",
      "timeoutSeconds": 45
    }
  ],
  "maxIterations": 5,
  "maxFixAttempts": 3,
  "maxCiAutoResumes": 10,
  "provider": "anthropic",
  "model": "claude-opus-4-6",
  "skipAiSummary": false,
  "autoIncludeContexts": true,
  "logWatchEnabled": true,
  "healthCheckEnabled": true,
  "preflightCheckEnabled": true,
  "enableSweep": false,
  "maxSweepIterations": 5,
  "stopOnFailure": false,
  "approvalGate": false,
  "reflectionMode": true,
  "completionPromptsFirst": false,
  "isFavorite": false,
  "multiAgentMode": true,
  "enforceTokenBudget": false,
  "strictCwd": false,
  "useWorktree": false,
  "workflowArchitecture": "traditional",
  "aiReviewed": true,
  "createdAt": "2026-04-10T08:00:00Z",
  "modified_at": "2026-04-14T09:00:00Z",
  "htnEnabled": false
}
