{
  "id": "bbbbbbbb-cccc-4ddd-8eee-ffffffffffff",
  "name": "Full runner step coverage",
  "description": "Exercises every FullRunnerStep variant across the four workflow phases — acts as a cross-language DB round-trip fixture.",
  "category": "ci",
  "tags": ["coverage", "round-trip", "example"],
  "setup_steps": [
    {
      "type": "command",
      "id": "setup-clone-0001",
      "name": "Clone repo",
      "phase": "setup",
      "mode": "shell",
      "command": "git clone https://github.com/jspahrsummers/qontinui-runner.git /tmp/runner",
      "working_directory": "/tmp",
      "timeout_seconds": 120,
      "fail_on_error": true
    },
    {
      "type": "command",
      "id": "setup-lint-0002",
      "name": "Cargo clippy",
      "phase": "setup",
      "mode": "check",
      "check_type": "lint",
      "tool": "cargo-clippy",
      "command": "cargo clippy --all-targets -- -D warnings",
      "working_directory": "/tmp/runner/src-tauri"
    },
    {
      "type": "ui_bridge",
      "id": "setup-nav-0003",
      "name": "Open runner home page",
      "phase": "setup",
      "action": "navigate",
      "url": "http://localhost:1420/",
      "timeout_ms": 15000
    },
    {
      "type": "code_execution",
      "id": "setup-pycheck-0004",
      "name": "Probe DB readiness",
      "code": "import psycopg2; psycopg2.connect('postgresql://localhost/qontinui').close(); print('db-ok')",
      "sandbox_mode": "enforce",
      "timeout_seconds": 20
    },
    {
      "type": "restart_process",
      "id": "setup-restart-0005",
      "name": "Restart backend before tests",
      "restart_process_name": "qontinui-backend",
      "restart_wait_for_health": true,
      "timeout_seconds": 60
    }
  ],
  "verification_steps": [
    {
      "type": "command",
      "id": "verify-tests-0101",
      "name": "Run cargo test",
      "phase": "verification",
      "mode": "test",
      "test_type": "repository",
      "command": "cargo test --workspace",
      "working_directory": "/tmp/runner/src-tauri",
      "timeout_seconds": 600,
      "fail_on_error": true
    },
    {
      "type": "ui_bridge",
      "id": "verify-assert-0102",
      "name": "Assert login button visible",
      "phase": "verification",
      "action": "assert",
      "target": "#login-button",
      "assert_type": "visible",
      "expected": "true",
      "timeout_ms": 8000
    },
    {
      "type": "ui_bridge_visual_assertion",
      "id": "verify-visual-0103",
      "name": "Assert header text",
      "visual_assertion_type": "text",
      "visual_assertion_query": { "role": "heading", "level": 1 },
      "visual_assertion_expected": "Qontinui Runner",
      "timeout_seconds": 10
    },
    {
      "type": "workflow_fixup",
      "id": "verify-fixup-0104",
      "name": "Validate generated workflow",
      "fixup_input_path": "{{artifact_dir}}/workflow.json",
      "fixup_mode": "validate_criteria",
      "fixup_criteria_path": "{{artifact_dir}}/criteria.json"
    }
  ],
  "agentic_steps": [
    {
      "type": "prompt",
      "id": "agentic-fix-0201",
      "name": "Fix failing tests",
      "phase": "agentic",
      "content": "Read the failing cargo test output and propose a minimal patch that makes the tests pass without regressing behaviour.",
      "provider": "anthropic",
      "model": "claude-opus-4-6"
    },
    {
      "type": "native_accessibility",
      "id": "agentic-a11y-0202",
      "name": "Snapshot active window",
      "action": "ai_context",
      "target": "Desktop",
      "interactive_only": true,
      "max_elements": 50,
      "timeout_seconds": 15
    }
  ],
  "completion_steps": [
    {
      "type": "command",
      "id": "complete-report-0301",
      "name": "Emit summary report",
      "phase": "completion",
      "mode": "shell",
      "command": "python scripts/emit_summary.py --artifact-dir {{artifact_dir}}",
      "working_directory": "/tmp/runner"
    },
    {
      "type": "save_workflow_artifact",
      "id": "complete-save-0302",
      "name": "Persist generated workflow",
      "artifact_input_path": "{{artifact_dir}}/workflow.json",
      "artifact_capture_prompts": true
    },
    {
      "type": "workflow",
      "id": "complete-subwf-0303",
      "name": "Run notification subworkflow",
      "phase": "completion",
      "workflow_id": "wf-notify-9001",
      "workflow_name": "Post-run notification"
    },
    {
      "type": "ui_bridge_design_audit",
      "id": "complete-audit-0304",
      "name": "Design audit on final page",
      "timeout_seconds": 45
    }
  ],
  "max_iterations": 5,
  "max_fix_attempts": 3,
  "max_ci_auto_resumes": 10,
  "provider": "anthropic",
  "model": "claude-opus-4-6",
  "skip_ai_summary": false,
  "auto_include_contexts": true,
  "log_watch_enabled": true,
  "health_check_enabled": true,
  "preflight_check_enabled": true,
  "enable_sweep": false,
  "max_sweep_iterations": 5,
  "stop_on_failure": false,
  "approval_gate": false,
  "reflection_mode": true,
  "completion_prompts_first": false,
  "is_favorite": false,
  "multi_agent_mode": true,
  "enforce_token_budget": false,
  "strict_cwd": false,
  "use_worktree": false,
  "workflow_architecture": "traditional",
  "ai_reviewed": true,
  "created_at": "2026-04-10T08:00:00Z",
  "modified_at": "2026-04-14T09:00:00Z"
}
