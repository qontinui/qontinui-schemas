  "category": "ci",
  "tags": [
    "build",
    "test",
    "example"
  ],
  "setupSteps": [],
  "verificationSteps": [],
  "agenticSteps": [],
  "completionSteps": [],
  "maxIterations": 5,
  "maxFixAttempts": 3,
  "maxCiAutoResumes": 10,
  "provider": "anthropic",
  "model": "claude-opus-4-6",
  "modelOverrides": {
    "verification": {
      "provider": "anthropic",
      "model": "claude-haiku-4",
      "temperature": 0.2
    }
  },
  "skipAiSummary": false,
  "logSourceSelection": {
    "profile_id": "runner-default-profile"
  },
  "autoIncludeContexts": true,
  "logWatchEnabled": true,
  "healthCheckEnabled": true,
  "healthCheckUrls": [
    {
      "name": "Backend API",
      "url": "http://localhost:8000/health",
      "expectedStatus": 200,
      "timeoutSeconds": 30,
      "isCritical": true
    }
  ],
  "preflightCheckEnabled": true,
  "enableSweep": false,
  "maxSweepIterations": 5,
  "stages": [
    {
      "id": "stage-build-0001",
      "name": "Build",
      "description": "Compile the runner workspace.",
      "setupSteps": [],
      "verificationSteps": [],
      "agenticSteps": [],
      "completionSteps": [],
      "maxIterations": 3,
      "approvalGate": false,
      "completionPromptsFirst": false,
      "outputs": [
        {
          "key": "build_artifact_path",
          "description": "Path to the built artifact."
        }
      ]
    },
    {
      "id": "stage-test-0002",
      "name": "Test",
      "description": "Run the test suite against the build artifact.",
      "setupSteps": [],
      "verificationSteps": [],
      "agenticSteps": [],
      "completionSteps": [],
      "maxIterations": 5,
      "approvalGate": false,
      "condition": {
        "ifPrevious": "passed"
      },
      "completionPromptsFirst": false,
      "inputs": [
        {
          "key": "build_artifact_path",
          "fromStage": "stage-build-0001",
          "required": true
        }
      ]
    }
  ],
  "stopOnFailure": false,
  "approvalGate": false,
  "reflectionMode": true,
  "completionPromptsFirst": false,
  "isFavorite": false,
  "multiAgentMode": true,
  "enforceTokenBudget": false,
  "strictCwd": false,
  "useWorktree": false,
  "workflowArchitecture": "traditional",
