{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": false,
  "pull-request-title-pattern": "chore${scope}: release ${component} ${version}",
  "extra-files": [
    "Cargo.lock"
  ],
  "packages": {
    "rust": {
      "release-type": "rust",
      "package-name": "qontinui-types",
      "component": "rust",
      "changelog-path": "CHANGELOG.md",
      "last-release-sha": "7cf1daf3e813d57c7fc9c9dddba08d9444311d65"
    },
    "rust-runner-client": {
      "release-type": "rust",
      "package-name": "qontinui-runner-client",
      "component": "rust-runner-client",
      "changelog-path": "CHANGELOG.md",
      "last-release-sha": "09e23448b6bf17ec8814324154b56009266dd592"
    },
    "ts": {
      "release-type": "node",
      "package-name": "@qontinui/shared-types",
      "component": "ts",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
